{
  "name": "parabellumkoval/backpack-settings",
  "description": "Settings UI & Service for Laravel 8 + Backpack 4.1 (config/DB drivers, tabs, registry, aliases).",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andrej Koval",
      "email": "example@example.com"
    },
    {
      "name": "Backpack Settings Generator",
      "email": "noreply@example.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "spatie/laravel-translatable": "^6.6"
  },
  "autoload": {
    "psr-4": {
      "Backpack\\Settings\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Backpack\\Settings\\Providers\\BackpackSettingsServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}